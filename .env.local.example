# DO NOT COMMIT .env.local — fill real values there, not here.
# This file (.env.local.example) is the public template only.

# --- Supabase ---------------------------------------------------------
# Get these from your Supabase project's Settings → API page.
# Use the PUBLISHABLE anon key (sb_publishable_...), not the secret/service-role key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here

# --- Anthropic --------------------------------------------------------
# Create a key at https://console.anthropic.com/settings/keys
# Model used by the app: claude-sonnet-4-6 (see src/lib/ai/anthropic.ts).
ANTHROPIC_API_KEY=sk-ant-your-key-here
